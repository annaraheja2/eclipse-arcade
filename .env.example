# Firebase web app config (Phase 1 of accounts — see src/lib/firebase.ts).
# Copy to .env.local and fill in the real values from the Firebase console.
# All six must be set for auth/sync to activate; with any missing, the app
# runs exactly as before (no sign-in UI, localStorage-only player state).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
