rules_version = '2';

// ============================================================================
// SHARED Eclipse Firebase project (eclipse-learning-97944)
//
// This one project backs BOTH Eclipse family apps:
//   - Eclipse Learning (~/app/studyreel-web): content, shorts, users, reflections
//   - Eclipse Arcade  (this repo):            players
//
// This file is the deployable source of truth for the WHOLE project — it must
// contain both apps' rules. Deploying a partial (single-app) ruleset would
// break the other app. Keep studyreel-web/firestore.rules in sync or retire it
// in favor of this file.
//
// These rules are the REAL enforcement; the client-side checks
// (src/lib/admin.ts, isAdmin in src/lib/auth.tsx) are UI gating only and must
// never be trusted.
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // Owner/master accounts for Eclipse Learning — semantics IDENTICAL to the
    // ruleset currently deployed for studyreel-web (no email_verified check),
    // so publishing this file cannot change any live Learning behavior.
    //
    // KNOWN GAP (deliberate, pending verification): without email_verified, an
    // email/password signup merely CLAIMING one of these addresses would pass.
    // Add `&& request.auth.token.email_verified == true` here ONLY after
    // confirming in the Auth console that all three owner accounts use the
    // Google provider (auto-verified) — otherwise a live owner gets locked out.
    function isOwner() {
      return request.auth != null
        && request.auth.token.email in [
          'annaraheja2@gmail.com',
          'alexleyvalp@gmail.com',
          'f.nguyen088@gmail.com'
        ];
    }

    // Eclipse Arcade admins — a NEW surface, so the email_verified hardening is
    // safe here (worst case an unverified admin loses only the extra admin
    // reads; no existing behavior can break). Google sign-in is always
    // verified. f.nguyen088@gmail.com is a Learning owner but has NOT been
    // confirmed as an arcade admin — if that changes, add them here.
    function isArcadeAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['annaraheja2@gmail.com', 'alexleyvalp@gmail.com'];
    }

    // ------------------- Eclipse Learning (studyreel-web) -------------------
    // Clause-for-clause identical to studyreel-web/firestore.rules.

    // Course content: anyone can read (even signed-out visitors); only owners can edit.
    match /content/{doc} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Short videos feed: anyone can watch; only owners (creators) can post/delete.
    match /shorts/{id} {
      allow read: if true;
      allow write: if isOwner();
    }

    // Each signed-in user can read & write ONLY their own progress document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // "Explain it back" reflections. Students create their own; owners read all.
    match /reflections/{id} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read: if isOwner()
                  || (request.auth != null && resource.data.userId == request.auth.uid);
      allow delete: if isOwner();
    }

    // --------------------------- Eclipse Arcade -----------------------------

    // Each player owns exactly their own arcade progress doc; arcade admins can
    // additionally read any player (admin write/moderation arrives in a later
    // phase). Writes are shape-constrained and the stored email must match the
    // signed-in account, so a player cannot stamp someone else's address into a
    // field admins will later read.
    match /players/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid) || isArcadeAdmin();
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.email == request.auth.token.email
        // Defense-in-depth: these fields are all OPTIONAL on the doc (different
        // write paths include different subsets), but when present each must
        // carry the right type — a string handle/pref, a numeric counter.
        && (!('username' in request.resource.data)
            || request.resource.data.username is string)
        && (!('preferredCourseId' in request.resource.data)
            || request.resource.data.preferredCourseId is string)
        && (!('avatarColor' in request.resource.data)
            || request.resource.data.avatarColor is string)
        && (!('gamesPlayed' in request.resource.data)
            || request.resource.data.gamesPlayed is number)
        && (!('questionsAnswered' in request.resource.data)
            || request.resource.data.questionsAnswered is number)
        && (!('questionsCorrect' in request.resource.data)
            || request.resource.data.questionsCorrect is number)
        && request.resource.data.keys().hasOnly(
             ['coins', 'xp', 'streak', 'lastPlayed', 'bests', 'email', 'updatedAt', 'username',
              'gamesPlayed', 'questionsAnswered', 'questionsCorrect', 'preferredCourseId', 'avatarColor']);
      // Self-delete for account deletion (Settings → Data & Privacy). The client
      // fan-out also clears the player's usernames/friendships/friendRequests/
      // matchQueue docs, each already owner-deletable by its own rule.
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Unique, server-reserved usernames. UNIQUENESS MECHANISM: the doc id IS the
    // lowercased handle (usernameLower), and creates are gated to
    // id == username.lower() — so a handle maps to exactly one doc, and a
    // create fails if that doc already exists. There is deliberately NO update
    // rule: a rename is delete-old + create-new, done atomically in the
    // claimUsername transaction (see src/lib/username.ts), which reads the
    // target doc to serialize concurrent claims. Reads are PUBLIC — needed for
    // availability checks and uid->handle display lookups.
    match /usernames/{name} {
      allow read: if true;
      // FORMAT is enforced server-side (mirrors validateUsername) so a direct-SDK
      // caller can't reserve a malformed/overlong handle: matches() is a
      // full-string RE2 match, so this requires start-with-letter then
      // letters/digits/underscores, within 3–20 chars. The client's extra rules
      // (no double/trailing underscore) stay client-only.
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 20
        && request.resource.data.username.matches('[A-Za-z][A-Za-z0-9_]*')
        && name == request.resource.data.username.lower()
        && request.resource.data.keys().hasOnly(['uid', 'username', 'createdAt']);
      // A user may release ONLY their own reservation (so they can change it).
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Arcade curriculum content: one whole-course doc per course (see
    // src/lib/content.ts). Anyone can read — the game loads it signed-out;
    // only arcade admins can write, and the stored updatedBy must be the
    // writing admin's own email.
    match /arcadeContent/{courseId} {
      allow read: if true;
      allow write: if isArcadeAdmin()
        && request.resource.data.updatedBy == request.auth.token.email;
    }

    // ---------------- Eclipse Arcade — online play (PvP Battleship) ----------------
    // Trust model (see src/lib/social.ts): no game server; fleets never leave
    // the client. The shooter files a 'pending' shot; the DEFENDER adjudicates.
    //
    // NOTE: matchQueue and matches docs accumulate indefinitely — there is no
    // TTL/cleanup job yet (prototype). Revisit before opening to real traffic.

    function signedIn() { return request.auth != null; }
    // Identity surfaces (friendRequests, matchQueue, matches create) demand a
    // VERIFIED email: an email/password signup can claim any address before
    // verifying it, so without this check an attacker could impersonate a
    // victim's address — receiving their friend requests or posing as them in
    // matchmaking. Google sign-in is always verified.
    function verified() { return signedIn() && request.auth.token.email_verified == true; }
    // All social docs store emails lowercased (normalizeEmail in
    // src/lib/social.ts); comparing against the LOWERCASED token email avoids
    // case-mismatch permission-denials and keeps email-scoped queries
    // (subscribeIncomingRequests) provable.
    function myEmail() { return request.auth.token.email.lower(); }

    // Friend requests are addressed by (lowercased) email. Doc id is
    // DETERMINISTIC — `${fromUid}_${toEmail}` — which dedupes repeat requests
    // and lets the friendships create rule look the settled request up by id.
    match /friendRequests/{requestId} {
      allow read: if verified()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toEmail == myEmail());
      allow create: if verified()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.fromEmail == myEmail()
        && request.resource.data.toEmail is string
        && request.resource.data.toEmail == request.resource.data.toEmail.lower()
        && requestId == request.auth.uid + '_' + request.resource.data.toEmail
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly(
             ['fromUid', 'fromEmail', 'toEmail', 'status', 'createdAt']);
      // Only the recipient settles a request, exactly once, status-only.
      allow update: if verified()
        && resource.data.toEmail == myEmail()
        && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      // Either party to a request may delete it (cancel / cleanup). Unfriend
      // clears both directional accepted requests so the deterministic id can't
      // permanently block re-friending (see removeFriend in src/lib/social.ts).
      // Benign: deleting a request you sent or received only removes your own
      // pending/settled edge — it can't touch anyone else's relationships.
      allow delete: if verified()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toEmail == myEmail());
    }

    // Doc id = the two uids sorted and '_'-joined; created by the accepter.
    match /friendships/{pairId} {
      function reqPath(otherUid) {
        return /databases/$(database)/documents/friendRequests/$(otherUid + '_' + request.auth.token.email.lower());
      }
      // The settled request that authorizes the creator (the accepter) to
      // befriend `otherUid`. getAfter, not get: the accept flow settles the
      // request AND creates the friendship in ONE batch, and get() would
      // still see the pre-batch 'pending' status. getAfter is equally safe —
      // reaching 'accepted' post-batch requires passing the recipient-only
      // request update rule, and exists() (pre-batch state) blocks a request
      // forged inside the same batch. fromUid != creator: the accepter must
      // be the RECIPIENT of the request, never its sender.
      function acceptedRequestFrom(otherUid) {
        return exists(reqPath(otherUid))
          && getAfter(reqPath(otherUid)).data.status == 'accepted'
          && getAfter(reqPath(otherUid)).data.fromUid != request.auth.uid;
      }
      allow read: if signedIn() && request.auth.uid in resource.data.uids;
      // Two-branch check: rules can't know which of uids[0]/uids[1] is the
      // request's sender, so whichever slot ISN'T the creator must have sent
      // an accepted request to the creator's email.
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.uids
        && request.resource.data.uids.size() == 2
        && request.resource.data.uids[0] < request.resource.data.uids[1]
        && pairId == request.resource.data.uids[0] + '_' + request.resource.data.uids[1]
        && request.resource.data.keys().hasOnly(['uids', 'emails', 'createdAt'])
        && ((request.auth.uid == request.resource.data.uids[0]
              && acceptedRequestFrom(request.resource.data.uids[1]))
            || (request.auth.uid == request.resource.data.uids[1]
              && acceptedRequestFrom(request.resource.data.uids[0])));
      // Unfriend: either side may sever the friendship at any time.
      allow delete: if signedIn() && request.auth.uid in resource.data.uids;
    }

    // Quick-match queue: one doc per waiting player, id = uid. The doc now
    // carries the player's chosen topic + difficulty; `difficulty` is the field
    // the matches-create rule cross-checks so pairing is same-difficulty only.
    match /matchQueue/{uid} {
      allow read: if signedIn();
      allow create, update: if verified()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == myEmail()
        && request.resource.data.difficulty in ['easy', 'medium', 'hard']
        && request.resource.data.courseId is string
        && request.resource.data.unitId is string
        && request.resource.data.subunitId is string
        && request.resource.data.keys().hasOnly(
             ['uid', 'email', 'difficulty', 'courseId', 'unitId', 'subunitId', 'createdAt']);
      // Any signed-in user may delete entries: the pairing transaction
      // atomically removes BOTH its own and its opponent's queue doc.
      allow delete: if signedIn();
    }

    match /matches/{matchId} {
      function isParticipant() {
        return signedIn() && request.auth.uid in resource.data.players;
      }
      function pairIdOf(a, b) { return a < b ? a + '_' + b : b + '_' + a; }
      function queuePath(u) { return /databases/$(database)/documents/matchQueue/$(u); }
      // A per-player topic selection carried on the match. Only type-checked —
      // the AUTHORITATIVE same-difficulty constraint is enforced below by
      // comparing the two players' queue docs, not these fields.
      function validSel(s) {
        return s.courseId is string
          && s.unitId is string
          && s.subunitId is string
          && s.difficulty in ['easy', 'medium', 'hard'];
      }
      allow read: if isParticipant();
      // players[0] is always the creator (inviter / quick-match pairer).
      // Relationship gating: an 'invite' requires an existing friendship with
      // the invitee; a 'placing' match (quick-match pairing) requires the
      // opponent to be waiting in the queue. exists() sees PRE-transaction
      // state, so the pairing transaction (create match + delete both queue
      // docs) still passes.
      allow create: if verified()
        && request.resource.data.keys().hasOnly(
             ['players', 'emails', 'status', 'turn', 'winner', 'endReason',
              'sel', 'ready', 'createdAt', 'updatedAt'])
        && request.resource.data.players.size() == 2
        && request.resource.data.players[0] == request.auth.uid
        && request.resource.data.players[0] != request.resource.data.players[1]
        && request.resource.data.status in ['invite', 'placing']
        && request.resource.data.turn in request.resource.data.players
        && request.resource.data.winner == null
        // The creator's own email in the map must be their real (verified)
        // address. The OPPONENT's entry is display-only / unverified — the
        // creator supplies it (from a friendship or the queue) and the client
        // only ever shows it, never trusts it for authorization.
        && request.resource.data.emails[request.auth.uid] == myEmail()
        // Each player carries a well-typed topic selection. A client trusts
        // only its OWN entry (to load its questions) and degrades gracefully,
        // so this is a shape check — difficulty MATCHING is enforced below.
        && request.resource.data.sel is map
        && request.resource.data.players[0] in request.resource.data.sel
        && request.resource.data.players[1] in request.resource.data.sel
        && validSel(request.resource.data.sel[request.resource.data.players[0]])
        && validSel(request.resource.data.sel[request.resource.data.players[1]])
        && ((request.resource.data.status == 'invite'
              && exists(/databases/$(database)/documents/friendships/$(pairIdOf(request.resource.data.players[0], request.resource.data.players[1]))))
            // Quick-match: BOTH the creator (players[0]) AND the opponent
            // (players[1]) must be genuinely queued — so a verified user can't
            // spam placing-matches at a queued player — AND their two queue
            // docs must carry the SAME difficulty, which is what makes pairing
            // same-difficulty-only unbypassable server-side (a hacked client
            // that skips the client filter still cannot pair across tiers).
            // exists()/get() see PRE-transaction state, so attemptPair (which
            // created its own queue doc first, then deletes both in the pairing
            // transaction) still passes.
            || (request.resource.data.status == 'placing'
              && exists(queuePath(request.resource.data.players[0]))
              && exists(queuePath(request.resource.data.players[1]))
              && get(queuePath(request.resource.data.players[0])).data.difficulty
                   == get(queuePath(request.resource.data.players[1])).data.difficulty));
      // Participants drive the state machine FORWARD only (accept, ready,
      // turn flips, shot adjudication side-effects, forfeit/timeout). It never
      // rewinds: 'invite' is not a permitted target (which would re-open the
      // delete window), and the one remaining backward edge — active->placing,
      // which would let a losing player reset a live match to placement — is
      // explicitly forbidden. Still allowed: invite->placing (accept),
      // placing->active (both ready), ready toggles within placing, and
      // {placing,active}->done. Winner is set iff the match is done, identity
      // fields are frozen via affectedKeys, and finished matches are immutable.
      allow update: if isParticipant()
        && resource.data.status != 'done'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['status', 'turn', 'winner', 'endReason', 'ready', 'updatedAt'])
        && request.resource.data.status in ['placing', 'active', 'done']
        && !(resource.data.status == 'active' && request.resource.data.status == 'placing')
        && ((request.resource.data.status == 'done')
            == (request.resource.data.winner != null))
        && (request.resource.data.endReason == null
            || request.resource.data.endReason in ['fleet-sunk', 'forfeit', 'timeout'])
        && request.resource.data.turn in resource.data.players
        && (request.resource.data.winner == null
            || request.resource.data.winner in resource.data.players);
      // Only an unaccepted invite may be removed (decline / cancel).
      allow delete: if isParticipant() && resource.data.status == 'invite';

      match /shots/{shotId} {
        function matchData() {
          return get(/databases/$(database)/documents/matches/$(matchId)).data;
        }
        allow read: if signedIn() && request.auth.uid in matchData().players;
        // Only the shooter, only on their turn, only in a live match; every
        // shot starts unadjudicated and on the 8x8 board.
        allow create: if signedIn()
          && request.auth.uid in matchData().players
          && matchData().status == 'active'
          && matchData().turn == request.auth.uid
          && request.resource.data.by == request.auth.uid
          && request.resource.data.result == 'pending'
          && request.resource.data.r is int && request.resource.data.r >= 0 && request.resource.data.r < 8
          && request.resource.data.c is int && request.resource.data.c >= 0 && request.resource.data.c < 8
          && request.resource.data.keys().hasOnly(['by', 'r', 'c', 'seq', 'result', 'createdAt']);
        // Only the DEFENDER adjudicates, exactly once, result field only, and
        // only while the match is still live.
        allow update: if signedIn()
          && request.auth.uid in matchData().players
          && request.auth.uid != resource.data.by
          && matchData().status == 'active'
          && resource.data.result == 'pending'
          && request.resource.data.result in ['miss', 'hit', 'sunk']
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['result']);
      }
    }

    // Anything not matched above is denied (Firestore's implicit default;
    // stated here for clarity).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
